# md2docx 단계별 설정 토글
#
# 형식: KEY=VALUE  (한 줄에 하나, # 으로 주석)
# 값:   true / false / 1 / 0 / yes / no  (대소문자 무관)
# 이름 규약: <단계>_APPLY_<속성>
#
# 이 파일은 skill 루트(.claude/skills/md2docx/) 에 둔다.
# 각 후처리 스크립트가 직접 읽어 토글에 따라 동작 분기한다.

# ====== postprocess_userlist (단계 5.5) ======
# cluster 의 rPr (rFonts / sz / color 등) 을 marker run · 기존 run 에 적용할지.
# false → marker 와 기존 run 모두 본문 폰트(바탕글) 유지. cluster 의 폰트 정보 무시.
USERLIST_APPLY_RPR=false

# cluster 의 들여쓰기(<w:ind>: left/hanging/firstLine) 적용 여부.
# false → 단락의 기존 ind 유지 (pandoc 이 박은 값 그대로).
USERLIST_APPLY_INDENT=true

# cluster 의 줄간격(<w:spacing>) 적용 여부.
# false → 단락의 기존 spacing 유지.
USERLIST_APPLY_SPACING=true

# cluster 의 정렬(<w:jc>) 적용 여부.
# false → 단락의 기존 jc 유지.
USERLIST_APPLY_JC=true
